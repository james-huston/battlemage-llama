# Copy this file to .env and edit as needed. .env is gitignored.

# Host group IDs for GPU access. Check with:
#   getent group render video
# Stock Ubuntu 24+ / 25+ usually has render=993 video=44. If your host differs
# (Fedora uses 104 and 39, Arch often uses something else), override here.
# RENDER_GID=993
# VIDEO_GID=44

# Where your GGUF models live on the host. Default reuses Ollama's blob dir.
# If you downloaded GGUFs directly from Hugging Face, point this at whatever
# directory holds them. The dir is bind-mounted read-only inside the container
# at /models/, so your llama-swap config should reference paths under /models/.
# MODELS_DIR=/opt/apps/ollama-models

# ---------------------------------------------------------------------------
# LiteLLM sync (scripts/sync-litellm.py / `make sync-litellm`). Optional —
# only needed if you mirror this stack's models into a LiteLLM proxy. These
# can also be passed as flags / Make vars; values here are the fallback.
# ---------------------------------------------------------------------------
# Admin/master key for the LiteLLM proxy. Read here so it stays in gitignored
# .env rather than your shell history. Never committed.
# LITELLM_API_KEY=sk-...
#
# LiteLLM proxy admin base URL.
# LITELLM_URL=http://localhost:4000
#
# Base URL this script reads /v1/models from (this stack's llama-swap).
# UPSTREAM_URL=http://localhost:11434
#
# api_base baked into each LiteLLM model. If LiteLLM runs on another host this
# MUST be routable from there — use the model server's IP/hostname, not
# localhost. e.g. http://10.0.0.5:11434/v1
# MODEL_API_BASE=http://localhost:11434/v1

# ---------------------------------------------------------------------------
# Civitai (scripts/add-model.sh REPO=civitai:<modelVersionId>).
# ---------------------------------------------------------------------------
# Bearer token from https://civitai.com/user/account (API Keys section). Sent as
# Authorization: Bearer ... — required for gated downloads, recommended for
# public ones too (better rate limits). Never committed (.env is gitignored).
# CIVITAI_API_KEY=
