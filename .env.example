# Copy this file to .env and edit as needed. .env is gitignored.

# Host group IDs for GPU access. Check with:
#   getent group render video
# Stock Ubuntu 24+ / 25+ usually has render=993 video=44. If your host differs
# (Fedora uses 104 and 39, Arch often uses something else), override here.
# RENDER_GID=993
# VIDEO_GID=44

# Where your GGUF models live on the host. Default reuses Ollama's blob dir.
# If you downloaded GGUFs directly from Hugging Face, point this at whatever
# directory holds them. The dir is bind-mounted read-only inside the container
# at /models/, so your llama-swap config should reference paths under /models/.
# MODELS_DIR=/opt/apps/ollama-models
